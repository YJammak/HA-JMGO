# JMGO 投影仪遥控器 - Mushroom 卡片配置
# 需要先通过 HACS 安装 Mushroom Cards: https://github.com/piitaya/lovelace-mushroom

# ============================================
# 方案 1：简洁遥控器（使用 Chips）
# ============================================
type: vertical-stack
cards:
  - type: markdown
    content: |
      ## 🎬 投影仪遥控

  # 电源控制
  - type: horizontal-stack
    cards:
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_power
            icon: mdi:power
            icon_color: red
            content_info: name
            name: 电源
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_power

  # 方向键区域
  - type: horizontal-stack
    cards:
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_left
            icon: mdi:chevron-left
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_left
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_up
            icon: mdi:chevron-up
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_up
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_ok
            icon: mdi:checkbox-marked-circle
            icon_color: green
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_ok
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_down
            icon: mdi:chevron-down
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_down
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_right
            icon: mdi:chevron-right
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_right

  # 功能键
  - type: horizontal-stack
    cards:
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_return
            icon: mdi:arrow-left
            icon_color: orange
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_return
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_menu
            icon: mdi:menu
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_menu
      - type: custom:mushroom-chips-card
        chips:
          - type: entity
            entity: button.客厅投影仪_settings
            icon: mdi:cog
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.客厅投影仪_settings

# ============================================
# 方案 2：使用 Entity Cards（更现代）
# ============================================
type: vertical-stack
cards:
  - type: custom:mushroom-title-card
    title: 投影仪遥控
    subtitle: 客厅

  # 电源
  - type: custom:mushroom-entity-card
    entity: button.客厅投影仪_power
    icon: mdi:power
    icon_color: red
    name: 电源
    primary_info: name
    secondary_info: last-changed
    tap_action:
      action: call-service
      service: button.press
      target:
        entity_id: button.客厅投影仪_power
    layout: horizontal

  # 方向控制卡片
  - type: horizontal-stack
    cards:
      - type: custom:mushroom-entity-card
        entity: button.客厅投影仪_up
        icon: mdi:chevron-up
        name: 上
        primary_info: name
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_up
        layout: vertical
      - type: custom:mushroom-entity-card
        entity: button.客厅投影仪_down
        icon: mdi:chevron-down
        name: 下
        primary_info: name
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_down
        layout: vertical

  - type: horizontal-stack
    cards:
      - type: custom:mushroom-entity-card
        entity: button.客厅投影仪_left
        icon: mdi:chevron-left
        name: 左
        primary_info: name
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_left
        layout: vertical
      - type: custom:mushroom-entity-card
        entity: button.客厅投影仪_ok
        icon: mdi:checkbox-marked-circle
        icon_color: green
        name: 确认
        primary_info: name
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_ok
        layout: vertical
      - type: custom:mushroom-entity-card
        entity: button.客厅投影仪_right
        icon: mdi:chevron-right
        name: 右
        primary_info: name
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_right
        layout: vertical

  # 功能键
  - type: horizontal-stack
    cards:
      - type: custom:mushroom-entity-card
        entity: button.客厅投影仪_return
        icon: mdi:arrow-left
        icon_color: orange
        name: 返回
        primary_info: name
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_return
        layout: vertical
      - type: custom:mushroom-entity-card
        entity: button.客厅投影仪_menu
        icon: mdi:menu
        name: 菜单
        primary_info: name
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_menu
        layout: vertical
      - type: custom:mushroom-entity-card
        entity: button.客厅投影仪_settings
        icon: mdi:cog
        name: 设置
        primary_info: name
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_settings
        layout: vertical

# ============================================
# 方案 3：Template Cards（最灵活）
# ============================================
type: vertical-stack
cards:
  - type: custom:mushroom-title-card
    title: 🎬 投影仪控制

  # 电源按钮
  - type: custom:mushroom-template-card
    primary: 电源
    secondary: 点击切换电源
    icon: mdi:power
    icon_color: red
    entity: button.客厅投影仪_power
    tap_action:
      action: call-service
      service: button.press
      target:
        entity_id: button.客厅投影仪_power
    layout: horizontal
    fill_container: false
    multiline_secondary: false

  # 方向键组
  - type: custom:mushroom-chips-card
    alignment: center
    chips:
      - type: template
        entity: button.客厅投影仪_up
        icon: mdi:chevron-up
        icon_color: blue
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_up
      - type: template
        entity: button.客厅投影仪_down
        icon: mdi:chevron-down
        icon_color: blue
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_down
      - type: template
        entity: button.客厅投影仪_left
        icon: mdi:chevron-left
        icon_color: blue
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_left
      - type: template
        entity: button.客厅投影仪_right
        icon: mdi:chevron-right
        icon_color: blue
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_right
      - type: template
        entity: button.客厅投影仪_ok
        icon: mdi:checkbox-marked-circle
        icon_color: green
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_ok

  # 功能键组
  - type: custom:mushroom-chips-card
    alignment: center
    chips:
      - type: template
        entity: button.客厅投影仪_return
        icon: mdi:arrow-left
        icon_color: orange
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_return
      - type: template
        entity: button.客厅投影仪_menu
        icon: mdi:menu
        icon_color: purple
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_menu
      - type: template
        entity: button.客厅投影仪_settings
        icon: mdi:cog
        icon_color: grey
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_settings

# ============================================
# 方案 4：音量控制（如果媒体播放器可用）
# ============================================
type: vertical-stack
cards:
  - type: custom:mushroom-media-player-card
    entity: media_player.客厅投影仪
    use_media_info: false
    use_media_artwork: false
    show_volume_level: true
    volume_controls:
      - volume_set
      - volume_buttons
    media_controls: []
    collapsible_controls: true
