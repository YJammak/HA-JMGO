# JMGO 投影仪音量控制 - Mushroom 卡片配置

# ============================================
# 方案 1：使用 Number Card（推荐，滑块控制）
# ============================================
type: custom:mushroom-number-card
entity: number.客厅投影仪_volume
name: 音量
icon: mdi:volume-high
display_mode: slider
layout: horizontal
fill_container: true

# ============================================
# 方案 2：音量 + 遥控器组合
# ============================================
type: vertical-stack
cards:
  - type: custom:mushroom-title-card
    title: 投影仪控制

  # 音量滑块
  - type: custom:mushroom-number-card
    entity: number.客厅投影仪_volume
    name: 音量
    icon: mdi:volume-high
    display_mode: slider
    layout: horizontal
    fill_container: true

  # 遥控器按钮
  - type: custom:mushroom-chips-card
    alignment: center
    chips:
      - type: template
        entity: button.客厅投影仪_power
        icon: mdi:power
        icon_color: red
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_power
      - type: template
        entity: button.客厅投影仪_menu
        icon: mdi:menu
        icon_color: purple
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_menu
      - type: template
        entity: button.客厅投影仪_return
        icon: mdi:arrow-left
        icon_color: orange
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_return

# ============================================
# 方案 3：完整遥控器 + 音量
# ============================================
type: vertical-stack
cards:
  - type: custom:mushroom-title-card
    title: 🎬 投影仪遥控

  # 电源
  - type: custom:mushroom-template-card
    primary: 电源
    icon: mdi:power
    icon_color: red
    entity: button.客厅投影仪_power
    tap_action:
      action: call-service
      service: button.press
      target:
        entity_id: button.客厅投影仪_power

  # 音量控制
  - type: custom:mushroom-number-card
    entity: number.客厅投影仪_volume
    name: 音量
    icon: mdi:volume-high
    display_mode: slider
    layout: horizontal

  # 方向键
  - type: custom:mushroom-chips-card
    alignment: center
    chips:
      - type: template
        entity: button.客厅投影仪_left
        icon: mdi:chevron-left
        icon_color: blue
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_left
      - type: template
        entity: button.客厅投影仪_up
        icon: mdi:chevron-up
        icon_color: blue
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_up
      - type: template
        entity: button.客厅投影仪_ok
        icon: mdi:checkbox-marked-circle
        icon_color: green
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_ok
      - type: template
        entity: button.客厅投影仪_down
        icon: mdi:chevron-down
        icon_color: blue
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_down
      - type: template
        entity: button.客厅投影仪_right
        icon: mdi:chevron-right
        icon_color: blue
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_right

  # 功能键
  - type: custom:mushroom-chips-card
    alignment: center
    chips:
      - type: template
        entity: button.客厅投影仪_return
        icon: mdi:arrow-left
        icon_color: orange
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_return
      - type: template
        entity: button.客厅投影仪_menu
        icon: mdi:menu
        icon_color: purple
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_menu
      - type: template
        entity: button.客厅投影仪_settings
        icon: mdi:cog
        icon_color: grey
        tap_action:
          action: call-service
          service: button.press
          target:
            entity_id: button.客厅投影仪_settings

# ============================================
# 方案 4：使用 Media Player Card（集成控制）
# ============================================
type: custom:mushroom-media-player-card
entity: media_player.客厅投影仪
use_media_info: false
use_media_artwork: false
show_volume_level: true
volume_controls:
  - volume_set
  - volume_buttons
media_controls: []
collapsible_controls: true
icon: mdi:projector
